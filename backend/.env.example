# ====================================================
# ShopTrack Backend Environment Variables
# Copy this file to .env and fill in your values.
# ====================================================

# --- Database ---
POSTGRES_USER=shoptrack_user
POSTGRES_PASSWORD=your_strong_db_password_here
POSTGRES_DB=shoptrack_db
DATABASE_URL=postgresql://shoptrack_user:your_strong_db_password_here@db:5432/shoptrack_db

# --- Security ---
# Generate a strong secret: openssl rand -hex 32
JWT_SECRET_KEY=your_super_secret_key_here_please_change_me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# --- App ---
APP_ENV=production
CORS_ORIGINS=["http://localhost", "http://localhost:80"]
